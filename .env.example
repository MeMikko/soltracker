HELIUS_API_KEY=your_helius_api_key_here

# Option A: full connection string
# DATABASE_URL=mysql://user:password@host:3306/database

# Option B: MySQL parts (used on Vercel — auto-composed into DATABASE_URL)
MYSQL_HOST=your-mysql-host.example.com
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=your_database_name
MYSQL_PORT=3306
MYSQL_SSL=true

UPSTASH_REDIS_URL=https://your-instance.upstash.io
UPSTASH_REDIS_TOKEN=your_upstash_redis_token_here

# Optional: comma-separated wallet addresses with unlimited searches
# ADMIN_WALLETS=YourWalletPubkey1,YourWalletPubkey2

# Pro subscriptions bill 0.1 SOL/month to the treasury wallet below (override optional)
# PRO_TREASURY_WALLET=6fRPW1DWahcznCxzjg8V89FWP1fQ3y4tmkgzwzocjSzb