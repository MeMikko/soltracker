{
  "name": "solana-chain-intelligence",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/ensure-database-url.mjs && next dev",
    "build": "node scripts/ensure-database-url.mjs && prisma generate && node scripts/migrate-if-configured.mjs && next build",
    "start": "node scripts/ensure-database-url.mjs && next start",
    "lint": "next lint",
    "db:generate": "node scripts/ensure-database-url.mjs && prisma generate",
    "db:migrate": "node scripts/ensure-database-url.mjs && prisma migrate dev",
    "db:push": "node scripts/ensure-database-url.mjs && prisma db push",
    "test:smoke": "tsx --test src/lib/cache/cache.smoke.test.ts src/lib/riskScore.smoke.test.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "@solana/wallet-standard-features": "^1.4.0",
    "@solana/web3.js": "^1.98.4",
    "@upstash/redis": "^1.34.3",
    "@wallet-standard/app": "^1.1.1",
    "@wallet-standard/features": "^1.1.1",
    "bs58": "^6.0.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tweetnacl": "^1.0.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^6.1.0",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
